<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_main.xml — visual design reference for Android Studio Layout Editor.
  The actual UI is built programmatically in MainActivity.java for portability
  across Android Studio versions. This XML mirrors the programmatic layout.
-->
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SMS Gateway"
                android:textSize="24sp"
                android:textColor="#202124"
                android:paddingBottom="8dp" />

            <!-- Status Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:drawable/dialog_holo_light_frame"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/statusIndicator"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:background="@android:drawable/presence_offline" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp">

                        <TextView
                            android:id="@+id/statusText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Disconnected"
                            android:textSize="18sp"
                            android:textColor="#202124" />

                        <TextView
                            android:id="@+id/statusDetail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap START to connect"
                            android:textSize="13sp"
                            android:textColor="#5F6368" />
                    </LinearLayout>
                </LinearLayout>

                <Button
                    android:id="@+id/startStopBtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="START GATEWAY" />

                <TextView
                    android:id="@+id/serverHost"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Server: 192.168.1.100:2775"
                    android:textSize="11sp"
                    android:textColor="#80868B"
                    android:paddingTop="8dp" />
            </LinearLayout>

            <!-- Stats Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@android:drawable/dialog_holo_light_frame"
                    android:padding="12dp"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SMS Sent"
                        android:textSize="11sp"
                        android:textColor="#5F6368" />

                    <TextView
                        android:id="@+id/statSmsSent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:textColor="#1A73E8" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@android:drawable/dialog_holo_light_frame"
                    android:padding="12dp"
                    android:layout_marginStart="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SMS Rcvd"
                        android:textSize="11sp"
                        android:textColor="#5F6368" />

                    <TextView
                        android:id="@+id/statSmsRcvd"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:textColor="#34A853" />
                </LinearLayout>
            </LinearLayout>

            <!-- Stats Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@android:drawable/dialog_holo_light_frame"
                    android:padding="12dp"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Failed"
                        android:textSize="11sp"
                        android:textColor="#5F6368" />

                    <TextView
                        android:id="@+id/statSmsFailed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:textColor="#EA4335" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@android:drawable/dialog_holo_light_frame"
                    android:padding="12dp"
                    android:layout_marginStart="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DLRs"
                        android:textSize="11sp"
                        android:textColor="#5F6368" />

                    <TextView
                        android:id="@+id/statDlr"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:textColor="#FF9800" />
                </LinearLayout>
            </LinearLayout>

            <!-- Uptime -->
            <TextView
                android:id="@+id/statUptime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Uptime: --"
                android:textSize="13sp"
                android:textColor="#5F6368"
                android:paddingTop="8dp"
                android:paddingBottom="16dp" />

            <!-- Activity Log -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Activity Log"
                android:textSize="16sp"
                android:textColor="#202124"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:id="@+id/logContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:drawable/dialog_holo_light_frame"
                android:padding="16dp" />

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="16dp">

                <Button
                    android:id="@+id/settingsBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Settings"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/clearLogsBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Clear Logs"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
